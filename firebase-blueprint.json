{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "caretaker"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "companion"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "sender", "timestamp"]
    },
    "Memory": {
      "title": "Memory",
      "description": "A memory item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "createdAt"]
    },
    "TestConnection": {
      "title": "Test Connection",
      "description": "A document to test connection",
      "type": "object",
      "properties": {}
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Chat messages for a user"
    },
    "/users/{userId}/memories/{memoryId}": {
      "schema": { "$ref": "#/entities/Memory" },
      "description": "Memories for a user"
    },
    "/test/connection": {
      "schema": { "$ref": "#/entities/TestConnection" },
      "description": "Test connection document"
    }
  }
}
